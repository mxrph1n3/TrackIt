{
  "buildCommand": "npm run export:web",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/support",
      "destination": "/support.html"
    },
    {
      "source": "/((?!_expo/|assets/|favicon.ico|privacy.html|terms.html|support.html).*)",
      "destination": "/index.html"
    }
  ]
}
