{
  "name": "trackit2",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@g9k/expo-dynamic-app-icon": "^2.0.8",
    "@musclemap/assets": "^1.0.1",
    "@musclemap/core": "^1.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@supabase/supabase-js": "^2.108.2",
    "@twa-dev/sdk": "^8.0.2",
    "expo": "~56.0.15",
    "expo-auth-session": "~56.0.15",
    "expo-blur": "^56.0.3",
    "expo-haptics": "^56.0.3",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "~56.0.15",
    "expo-notifications": "~56.0.20",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "^56.0.5",
    "lucide-react-native": "^1.21.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-purchases": "^8.9.5",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.15",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "EXPO_USE_PRECOMPILED_MODULES=0 expo run:ios",
    "ios:xcode": "cd ios && pod install && open TrackIt.xcworkspace",
    "web": "expo start --web",
    "export:web": "expo export --platform web && node scripts/check-web-export.mjs",
    "build:web": "npm run export:web",
    "install:expo-go:ios": "bash scripts/install-expo-go-simulator.sh",
    "seed": "node seed.js",
    "assets:dark": "python3 scripts/generate-dark-theme-assets.py",
    "assets:icons": "python3 scripts/generate-app-icons.py --v4",
    "assets:icons:hub": "python3 scripts/generate-app-icons.py --hub",
    "setup:telegram-bot": "node scripts/setup-telegram-bot.mjs",
    "deploy:telegram": "bash scripts/deploy-telegram-functions.sh",
    "build:ios": "npx eas-cli@latest build --platform ios --profile production",
    "build:android": "npx eas-cli@latest build --platform android --profile production",
    "build:all": "npx eas-cli@latest build --platform all --profile production",
    "build:preview": "npx eas-cli@latest build --profile preview",
    "build:preview:android": "npx eas-cli@latest build --platform android --profile preview",
    "build:preview:ios": "npx eas-cli@latest build --platform ios --profile preview",
    "submit:ios": "npx eas-cli@latest submit --platform ios --profile production",
    "submit:android": "npx eas-cli@latest submit --platform android --profile production",
    "test": "CI=true jest --forceExit",
    "test:watch": "jest --watch"
  },
  "private": true,
  "overrides": {
    "expo-modules-core": "56.0.20",
    "@g9k/expo-dynamic-app-icon": {
      "expo-modules-core": "56.0.20"
    }
  }
}
