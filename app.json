{
  "expo": {
    "name": "TrackIt",
    "slug": "sadism",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-light.png",
    "userInterfaceStyle": "automatic",
    "scheme": "trackit2",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trackit.lifeos",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "TrackIt sends optional reminders for tasks, habits, workouts, and daily check-ins."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f0e6fa",
        "foregroundImage": "./assets/android-icon-light-foreground.png"
      },
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.trackit.lifeos",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "trackit2",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3F5FA",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#07070A",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-dark.png",
          "color": "#07070A"
        }
      ],
      [
        "@g9k/expo-dynamic-app-icon",
        {
          "obsidian": {
            "ios": "./assets/icon-dark.png",
            "android": {
              "foregroundImage": "./assets/android-icon-foreground.png",
              "backgroundColor": "#07070A"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "458381c2-cf7a-4a3d-a053-3a82eeeb187d"
      }
    }
  }
}
