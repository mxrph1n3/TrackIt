# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# Load EXPO_PUBLIC_* from the project `.env` so Release/Archive embeds
# Supabase (and other) keys into main.jsbundle. Without this, Metro leaves
# process.env.EXPO_PUBLIC_* empty and the app shows "Supabase is not configured".
_TRACKIT_ROOT="${SRCROOT:-}"
if [ -z "$_TRACKIT_ROOT" ] && [ -n "${PODS_ROOT:-}" ]; then
  _TRACKIT_ROOT="$(cd "$PODS_ROOT/.." && pwd)"
fi
if [ -n "$_TRACKIT_ROOT" ] && [ -f "$_TRACKIT_ROOT/../.env" ]; then
  set -a
  # shellcheck disable=SC1091
  . "$_TRACKIT_ROOT/../.env"
  set +a
elif [ -f "${PODS_ROOT:-}/../../.env" ]; then
  set -a
  # shellcheck disable=SC1091
  . "${PODS_ROOT}/../../.env"
  set +a
fi
unset _TRACKIT_ROOT
