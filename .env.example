# Supabase (required for auth + leaderboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for `npm run seed` (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Deep linking — add these exact redirect URLs in Supabase Dashboard:
# Authentication → URL Configuration → Redirect URLs
#
#   trackit2://auth/callback
#
# RevenueCat (App Store + Google Play subscriptions)
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_your_revenuecat_apple_key
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_your_revenuecat_google_key

# Product IDs (create in App Store Connect + Google Play Console):
#   trackit_pro_monthly  — $5.99/month
#   trackit_pro_yearly   — $59.99/year
# RevenueCat entitlement identifier: pro
